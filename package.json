{
  "name": "es3-qr-sdk",
  "version": "3.2.1",
  "description": "Sourcepoint TCF SDK for TV/OTT platforms with ES3 compatibility",
  "main": "example/nativeMessaging.js",
  "scripts": {
    "build": "rollup -c rollup.config.unified.mjs",
    "build:dev": "rollup -c rollup.config.unified.mjs --environment NODE_ENV:development",
    "build:tcf": "rollup -c rollup.config.unified.mjs --filter tcf",
    "build:main": "rollup -c rollup.config.unified.mjs --filter main",
    "watch": "rollup -c rollup.config.unified.mjs --watch",
    "clean": "rm -rf example/*.js example/*.js.map",
    "test:syntax": "node -c example/nativeMessaging.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "tcf",
    "sourcepoint",
    "consent",
    "tv",
    "hbbtv",
    "ott",
    "es3"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^7.25.9",
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-member-expression-literals": "^7.27.1",
    "@babel/plugin-transform-property-literals": "^7.27.1",
    "@babel/plugin-transform-reserved-words": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@iabtcf/core": "^1.5.6",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.51.0",
    "terser": "^5.36.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "example/",
    "src/",
    "tcfapi/",
    "README.md"
  ]
}
